<http://arhinet.arhiv.hr/details.aspx?ItemId=1_16069> a rico:RecordSet ;
    rico:identifier "HR-DAZG-857" ;
    rico:title "Zbirka Ulčnik Ivan (zbirka)" ;
    rico:hasOrHadAllMembersWithAccumulationDate [ a rico:DateRange ;
                                rico:expressedDate "1830-1955" ] ;
    rico:hasExtent [ a rico:RecordResourceExtent ;
        rico:quantity "3" ;
        rico:unitOfMeasurement "dm" ] ;
    rico:hasExtent [ a rico:RecordResourceExtent ;
        rico:quantity "30" ;
        rico:unitOfMeasurement "kutija" ] ;
    rico:hasCollector <http://arhinet.arhiv.hr/details.aspx?ItemId=3_21373> ;
    rico:scopeAndContent "Zbirka sadrži novinske izreske i fotografije koje je Ivan Ulčnik sakupio i bilješke koje je on sastavio. To se gradivo skoro u potpunosti odnosi na grad Zagreb, na njegovu povijest, na objekte, ljude i zbivanja u gradu od njegova osnutka do četrdesetih godina 20. stoljeća." ;
    rico:note "Izlučivanje: U fondu nije obavljeno odabiranje i izlučivanje. Gradivo se ne izlučuje, čuva se trajno. Stupanj sređenosti: Gradivo je arhivistički sređeno." ;
    rico:recordResourceStructure "Prilikom sređivanja zbirke rekonstruiran je prvobitni poredak kojeg je ustanovio Ivan Ulčnik, odnosno gradivo je sređeno u abecednom poretku. Zbirka se sastoji od tri serije: 1. Fotografije i tiskovine, 2. Bilješke i novinski izresci, 3. Razno." ;
    rico:conditionsOfAccess "Dostupnost: Dostupno javnosti. Uvjeti dostupnosti: Gradivo ima status javnostog gradiva. Dostupno je prema člancima 18-20 Zakona o arhivskom gradivu i arhivima te Pravilnikom o korištenju arhivskog gradiva." ;
    rico:conditionsOfUse "" ;
    rico:language "Croatian (hr)" , "Latin (latn)" ;
    rico:physicalCharacteristicsNote "Gradivo je sačuvano u relativno dobrom stanju." ;
    rico:isRelatedTo 
    [ rico:hasRecordResource <http://arhinet.arhiv.hr/details.aspx?ItemId=1_55816> ;
      rico:title "HR-DAZG-10 Gradsko poglavarstvo Zagreb" ;
      rico:note "(Osobnici činovnika i službenika Gradskog poglavarstva Zagreba, kut. 243, Personalni dosje Ivana Ulčnika)"
    ],
    [ rico:hasRecordResource <http://arhinet.arhiv.hr/details.aspx?ItemId=1_16006> ;
      rico:title "HR-DAZG-791 Društvo Zagrebčana"
    ] ;
    rico:note "Napomena o bibliografskim izvorima: Zagrebačka enciklopedija Ivana Ulčnika, Zagreb 2007. Izdavači: Zagrebačko arhivističko društvo i Državni arhiv u Zagrebu. Opća napomena:	Inventarni popis Zbirke Ulčnik Ivan, obogaćen dijelom fotografija iz Zbirke, izdan je 2007. kao knjiga: Zagrebačka enciklopedija Ivana Ulčnika, Zagreb 2007. Identifikator:	HR-DAZG/AJ 16069 Status zapisa:	izmijenjena inačica Podrobnost:	djelomičan opis" ;
    rico:hasOrHadDigitalInstantiation <https://ekultura.hr/item-sets/192968/> , <https://opensea.io/collection/known-unknowns-nft-ffzg> .
